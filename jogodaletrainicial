<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Figura → Letra Inicial</title>

<style>
body{
    margin:0;
    font-family:Arial, Helvetica, sans-serif;
    background:#eaf7ff;
    text-align:center;
}

h1{
    color:#1d4ed8;
    margin-top:20px;
}

#figura{
    font-size:120px;
    margin:30px;
}

#opcoes{
    display:grid;
    grid-template-columns:repeat(2,150px);
    gap:20px;
    justify-content:center;
}

.botao{
    background:white;
    border:3px solid #4b5563;
    border-radius:18px;
    font-size:60px;
    font-weight:bold;
    height:120px;
    cursor:pointer;
    transition:.2s;
    display:flex;
    justify-content:center;
    align-items:center;
}

.botao:hover{
    transform:scale(1.08);
    background:#dbeafe;
}

#mensagem{
    margin-top:30px;
    font-size:28px;
    font-weight:bold;
}

#placar{
    margin-top:15px;
    font-size:24px;
}

button{
    margin-top:20px;
    padding:12px 25px;
    font-size:18px;
    border:none;
    border-radius:12px;
    cursor:pointer;
}
</style>

</head>

<body>

<h1>Qual é a primeira letra?</h1>

<div id="figura"></div>

<div id="opcoes"></div>

<div id="mensagem"></div>

<div id="placar">
⭐ Acertos: <span id="pontos">0</span>
</div>

<button onclick="novaRodada()">Próxima</button>

<script>

const figuras=[
{emoji:"🍎", letra:"M"},
{emoji:"🍌", letra:"B"},
{emoji:"⚽", letra:"B"},
{emoji:"🐶", letra:"C"},
{emoji:"🐱", letra:"G"},
{emoji:"🐘", letra:"E"},
{emoji:"🐟", letra:"P"},
{emoji:"🌸", letra:"F"},
{emoji:"🌙", letra:"L"},
{emoji:"☀️", letra:"S"},
{emoji:"✈️", letra:"A"},
{emoji:"🍍", letra:"A"},
{emoji:"🚗", letra:"C"},
{emoji:"🎈", letra:"B"},
{emoji:"🦋", letra:"B"}
];

const letrasPossiveis=["A","B","C","E","F","G","L","M","P","S","T","U","V"];

let resposta;
let pontos=0;

function embaralhar(array){
    for(let i=array.length-1;i>0;i--){
        const j=Math.floor(Math.random()*(i+1));
        [array[i],array[j]]=[array[j],array[i]];
    }
    return array;
}

function novaRodada(){

    document.getElementById("mensagem").innerHTML="";

    resposta=figuras[Math.floor(Math.random()*figuras.length)];

    document.getElementById("figura").innerHTML=resposta.emoji;

    let opcoes=[resposta.letra];

    while(opcoes.length<4){

        let letra=letrasPossiveis[Math.floor(Math.random()*letrasPossiveis.length)];

        if(!opcoes.includes(letra))
            opcoes.push(letra);

    }

    embaralhar(opcoes);

    const div=document.getElementById("opcoes");

    div.innerHTML="";

    opcoes.forEach(letra=>{

        const botao=document.createElement("div");

        botao.className="botao";

        botao.innerHTML=letra;

        botao.onclick=function(){

            if(letra==resposta.letra){

                pontos++;

                document.getElementById("pontos").innerHTML=pontos;

                document.getElementById("mensagem").innerHTML="✅ Muito bem!";

                setTimeout(novaRodada,900);

            }else{

                document.getElementById("mensagem").innerHTML="❌ Tente novamente.";

            }

        }

        div.appendChild(botao);

    });

}

novaRodada();

</script>

</body>
</html>
